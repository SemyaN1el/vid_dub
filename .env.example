# Example environment for the online RouterAI + ElevenLabs configuration.
# The project does not auto-load this file. Copy values to your shell,
# system environment, or another secret manager.

MT_PROVIDER=openai_compatible
MT_MODEL_NAME=openai/gpt-5.4-mini
MT_STRATEGY=sentence-boundary-aware
MT_STYLE=compact
ROUTERAI_API_KEY=<your-routerai-key>
MT_OPENAI_API_KEY_ENV=ROUTERAI_API_KEY
MT_OPENAI_BASE_URL=https://<routerai-openai-compatible-endpoint>/v1
MT_OPENAI_RESPONSE_FORMAT=json_schema

# --- Direct OpenAI alternative (instead of the RouterAI block above) ---
# Leave MT_OPENAI_BASE_URL / SMART_SYNC_BASE_URL unset for api.openai.com.
# OPENAI_API_KEY=<your-openai-key>
# MT_PROVIDER=openai
# MT_MODEL_NAME=gpt-5.4-mini
# MT_OPENAI_API_KEY_ENV=OPENAI_API_KEY
# SMART_SYNC_PROVIDER=openai
# SMART_SYNC_MODEL_NAME=gpt-5.4-mini
# SMART_SYNC_API_KEY_ENV=OPENAI_API_KEY
# Optional cloud ASR via the same key (25 MB upload limit per file):
# ASR_PROVIDER=openai
# METRICS_ASR_PROVIDER=openai

TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=<your-elevenlabs-key>
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=pcm_24000

SMART_SYNC_ENABLED=1
SMART_SYNC_PROVIDER=openai_compatible
SMART_SYNC_MODEL_NAME=openai/gpt-5.4-mini
SMART_SYNC_API_KEY_ENV=ROUTERAI_API_KEY
SMART_SYNC_BASE_URL=https://<routerai-openai-compatible-endpoint>/v1
SMART_SYNC_CANDIDATES=3
SMART_SYNC_MAX_REWRITES=1

SUBTITLE_MODE=hard
ORIGINAL_GAIN=-22.0
